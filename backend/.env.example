# ---- App ----
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ---- Database ----
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./expense_manager.db
# Or Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/expense_manager

# ---- Optional AI Assistant (OpenAI) ----
# If left empty, the assistant falls back to a rule-based / local answer engine.
OPENAI_API_KEY=

# ---- OCR ----
# Path to tesseract binary if not on PATH (Windows example):
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
